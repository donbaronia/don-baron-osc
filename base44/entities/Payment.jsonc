{
  "name": "Payment",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Multi-tenant: empresa proprietaria"
    },
    "payment_code": {
      "type": "string",
      "description": "Codigo unico"
    },
    "financial_account_id": {
      "type": "string"
    },
    "financial_account_name": {
      "type": "string"
    },
    "cost_center_id": {
      "type": "string"
    },
    "cost_center_name": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "amount": {
      "type": "number",
      "default": 0
    },
    "due_date": {
      "type": "string",
      "format": "date"
    },
    "payment_date": {
      "type": "string",
      "format": "date"
    },
    "supplier_id": {
      "type": "string"
    },
    "supplier_name": {
      "type": "string"
    },
    "document_id": {
      "type": "string",
      "description": "Documento vinculado"
    },
    "purchase_id": {
      "type": "string",
      "description": "Compra vinculada"
    },
    "payment_method": {
      "type": "string",
      "enum": [
        "dinheiro",
        "pix",
        "transferencia",
        "boleto",
        "cartao_credito",
        "cartao_debito",
        "outros"
      ],
      "default": "pix"
    },
    "installments": {
      "type": "number",
      "default": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pendente",
        "pago",
        "parcial",
        "cancelado"
      ],
      "default": "pendente"
    },
    "notes": {
      "type": "string"
    },
    "version": {
      "type": "number",
      "default": 1
    },
    "deleted_at": {
      "type": "string",
      "format": "date-time"
    },
    "deleted_by": {
      "type": "string"
    }
  },
  "required": [
    "description",
    "amount"
  ]
}