{
  "name": "Recipe",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "description": "Multi-tenant: empresa proprietaria"
    },
    "name": {
      "type": "string"
    },
    "product_id": {
      "type": "string",
      "description": "Produto resultante da receita"
    },
    "product_name": {
      "type": "string"
    },
    "yield_quantity": {
      "type": "number",
      "default": 1,
      "description": "Rendimento da receita"
    },
    "yield_unit": {
      "type": "string"
    },
    "ingredients": {
      "type": "array",
      "items": {
        "type": "object"
      },
      "description": "Lista de ingredientes: {ingredient_id, name, quantity, unit, cost}"
    },
    "preparation_time": {
      "type": "number",
      "description": "Tempo de preparo em minutos"
    },
    "instructions": {
      "type": "string"
    },
    "cost_total": {
      "type": "number",
      "default": 0,
      "description": "Custo total calculado"
    },
    "cost_per_unit": {
      "type": "number",
      "default": 0,
      "description": "Custo por unidade calculado"
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "status": {
      "type": "string",
      "enum": [
        "ativo",
        "inativo",
        "arquivado"
      ],
      "default": "ativo"
    },
    "version": {
      "type": "number",
      "default": 1
    },
    "deleted_at": {
      "type": "string",
      "format": "date-time"
    },
    "deleted_by": {
      "type": "string"
    }
  },
  "required": [
    "name"
  ]
}